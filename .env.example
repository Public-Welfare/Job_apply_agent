OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# ── Fallback AI (used automatically when Ollama isn't running) ───────────
# Point at any free OpenAI-compatible provider. You can also paste a token
# from the dashboard instead of setting it here (stored in data/llm.json).
# Free options: groq (console.groq.com/keys), openrouter, gemini, cerebras.
LLM_PROVIDER=groq
LLM_API_KEY=
# Optional overrides (leave blank to use the provider's defaults):
LLM_BASE_URL=
LLM_MODEL=

# Gmail for email-based applications and reply tracking
EMAIL_USER=your@gmail.com
EMAIL_APP_PASSWORD=your_app_password_here

# Crawler settings
CRAWLER_DELAY_MS=2500
MAX_JOBS_PER_RUN=20

# Set to "true" to see the browser while crawling (good for debugging)
CRAWLER_HEADFUL=false

# ── Automatic daily crawl + job cache ──────────────────────────────────
# When the web server is running, auto-crawl in the background on a schedule.
AUTO_CRAWL=true
# How often the automatic crawl runs (hours). Default = once a day.
CRAWL_INTERVAL_HOURS=24
# How long a cached job description stays "fresh". While fresh, a user's search
# is served from the cache with NO crawl. Set 0 to always crawl live.
JOB_CACHE_TTL_HOURS=24
# Multi-source discovery: cap jobs pulled per company board (keeps runs bounded).
MAX_JOBS_PER_COMPANY=25

# ── Dashboard login (JWT) ──────────────────────────────────────────────
# Admin account — can ALWAYS start a crawl. CHANGE THESE.
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
# Regular user account — can only start a crawl when the last one was
# more than CRAWL_INTERVAL_HOURS ago. CHANGE THESE.
USER_USERNAME=user
USER_PASSWORD=user
# Secret used to sign JWTs — set to a long random string in production.
JWT_SECRET=please-change-this-to-a-long-random-string
# How long a login stays valid, in hours.
JWT_EXPIRE_HOURS=12
